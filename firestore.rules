rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin = any signed-in Firebase Authentication user. The admin panel is the
    // only place that signs in, so authenticated == authorized for admin actions.
    function isAdmin() {
      return request.auth != null;
    }

    // 1. Menu: herkes okuyabilir (site menüsü), sadece admin yazabilir/silebilir
    match /menu/{document} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // 2. Settings: herkes okuyabilir (site yapılandırması), sadece admin yazabilir
    match /settings/{document} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // 3. Reviews: herkes okuyabilir ve yeni yorum gönderebilir.
    //    Moderasyon (onay) ve silme yalnızca admin.
    match /reviews/{document} {
      allow read: if true;
      allow create: if request.resource.data.userName != null
                    && request.resource.data.comment != null;
      allow update, delete: if isAdmin();
    }

    // 4. Reservations: herkes rezervasyon oluşturabilir.
    //    Müşteri PII'si (telefon/e-posta) içerdiğinden OKUMA sadece admin'e açıktır.
    match /reservations/{document} {
      allow create: if request.resource.data.customerName != null
                    && request.resource.data.customerPhone != null;
      allow read, update, delete: if isAdmin();
    }

    // 5. Messages: herkes iletişim formu gönderebilir.
    //    PII içerdiğinden OKUMA sadece admin'e açıktır.
    match /messages/{document} {
      allow create: if request.resource.data.name != null
                    && request.resource.data.message != null;
      allow read, update, delete: if isAdmin();
    }

    // 6. Legal: herkes okuyabilir (yasal metinler), sadece admin yazabilir/silebilir
    match /legal/{document} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
