rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Menu rules: Anyone can read, only admin can write
    match /menu/{document} {
      allow read: if true;
      allow write: if false; // Only admin via Admin Console
    }
    
    // Reviews rules: Anyone can read, create, update, delete (needed for client-side admin dashboard)
    match /reviews/{document} {
      allow read: if true;
      allow create: if request.resource.data.userName != null 
                    && request.resource.data.comment != null;
      allow update, delete: if true;
    }
    
    // Reservations rules: Anyone can read, create, update, delete (needed for client-side admin dashboard)
    match /reservations/{document} {
      allow read, create, update, delete: if true;
    }
    
    // Messages rules: Anyone can read, create, delete (needed for client-side admin dashboard)
    match /messages/{document} {
      allow read, create, delete: if true;
    }
  }
}
