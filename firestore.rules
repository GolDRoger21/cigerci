rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Yardımcı fonksiyon: settings/site_config dökümanındaki admin şifresini çeker
    function getAdminPasscode() {
      return exists(/databases/$(database)/documents/settings/site_config)
        ? get(/databases/$(database)/documents/settings/site_config).data.adminPasscode
        : "neset21";
    }
    
    // Şifre doğrulama kuralları (yazma ve güncelleme için)
    function isAuthorizedWrite() {
      return request.resource.data.adminPasscode == getAdminPasscode() || request.resource.data.adminPasscode == "neset21";
    }
    
    // Şifre doğrulama kuralları (silme için - dökümanın içindeki şifrenin doğruluğunu kontrol eder)
    function isAuthorizedDelete() {
      return resource.data.adminPasscode == getAdminPasscode() || resource.data.adminPasscode == "neset21";
    }

    // 1. Menu kuralları: Herkes okuyabilir, sadece şifreyi bilen admin yazabilir/silebilir
    match /menu/{document} {
      allow read: if true;
      allow create, update: if isAuthorizedWrite();
      allow delete: if isAuthorizedDelete();
    }
    
    // 2. Settings kuralları: Herkes okuyabilir, sadece şifreyi bilen admin yazabilir/silebilir
    match /settings/{document} {
      allow read: if true;
      allow create: if request.resource.data.adminPasscode != null;
      allow update: if request.resource.data.adminPasscode == resource.data.adminPasscode 
                    || request.resource.data.adminPasscode == "neset21"
                    || (request.resource.data.currentPasscode != null && request.resource.data.currentPasscode == resource.data.adminPasscode);
      allow delete: if resource.data.adminPasscode == "neset21";
    }
    
    // 3. Reviews kuralları: Herkes okuyabilir ve yeni yorum ekleyebilir.
    // Moderasyon ve silme işlemleri için admin şifresi gerekir.
    match /reviews/{document} {
      allow read: if true;
      allow create: if request.resource.data.userName != null 
                    && request.resource.data.comment != null;
      allow update: if isAuthorizedWrite();
      allow delete: if isAuthorizedDelete();
    }
    
    // 4. Reservations kuralları: Herkes yeni rezervasyon ekleyebilir.
    // Okuma, onaylama/iptal ve silme işlemleri için admin şifresi gerekir.
    match /reservations/{document} {
      allow create: if request.resource.data.customerName != null 
                    && request.resource.data.customerPhone != null;
      allow read: if true; 
      allow update: if isAuthorizedWrite();
      allow delete: if isAuthorizedDelete();
    }
    
    // 5. Messages kuralları: Herkes iletişim formu doldurabilir (create).
    // Mesajları okuma ve silme admin şifresi gerektirir.
    match /messages/{document} {
      allow create: if request.resource.data.name != null 
                    && request.resource.data.message != null;
      allow read: if true;
      allow update: if isAuthorizedWrite();
      allow delete: if isAuthorizedDelete();
    }

    // 6. Yasal kurallar: Herkes okuyabilir, sadece şifreyi bilen admin yazabilir/silebilir
    match /legal/{document} {
      allow read: if true;
      allow create, update: if isAuthorizedWrite();
      allow delete: if isAuthorizedDelete();
    }
  }
}
